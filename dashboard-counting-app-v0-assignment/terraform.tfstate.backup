            "user_data": "#!/bin/bash\nset -e\n\n# Ubuntu uses apt\napt-get update -y\napt-get install -y unzip curl\n\n# Download Dashboard binary\ncurl -L https://github.com/hashicorp/demo-consul-101/releases/download/v0.0.5/dashboard-service_linux_amd64.zip \\\n  -o /tmp/dashboard.zip\ncd /tmp \u0026\u0026 unzip -o dashboard.zip\nmv /tmp/dashboard-service_linux_amd64 /usr/local/bin/dashboard-service\nchmod +x /usr/local/bin/dashboard-service\n\n# Create systemd service\ncat \u003c\u003c'SERVICE' \u003e /etc/systemd/system/dashboard.service\n[Unit]\nDescription=Dashboard Service\nAfter=network.target\n\n[Service]\nEnvironment=\"PORT=9002\"\nEnvironment=\"COUNTING_SERVICE_URL=http://172.16.2.10:9003\"\nExecStart=/usr/local/bin/dashboard-service\nRestart=always\nRestartSec=5\n\n[Install]\nWantedBy=multi-user.target\nSERVICE\n\nsystemctl daemon-reload\nsystemctl enable --now dashboard\n\n# Copy private key so Dashboard EC2 can SSH into Counting EC2\nmkdir -p /home/ubuntu/.ssh\necho \"-----BEGIN RSA PRIVATE KEY-----\nMIIJKQIBAAKCAgEA6Vw94k3W01+edpVPL5hWdbZEJyigmTFXfF2I74qwGdPBXLo5\ndcQmkGq0ofbyGJVD1SjFhYci31jLkL3XBUWNCGRU5hjfl5f4FBpr3KBR+SZyN2rg\nTBR9tPqvpFGlq0n3Ip9jRxjOqQclTvHwZL6aY8tJLCOSOLkdOGz5kJBEV6+iwBtJ\nlIKZ5rZQxCufHMjU5L/Wp4P9akAuvpvVY9j3P+HLuboWJJZfhTTT5VtDIKxzTeUV\n7tVCIKQ4hLlmTauGR7gWQrCvpoIMm/W6GxzBHI65lVpS3t7r9l08zjI3011zJuWy\nWI2OOM0TaPVSSYZ4Z0/PGH3QirPwrwSMsw/WQfWuPRlYFvjBUxNf4msbyqu0RwyE\nPut6LzCttS8t7sJFTsWLpnF58mWdT60eH7Y9kOQaCGkAMjYLjP0BK32A3cu5UWGc\nZTkzqebCtaD3wM6gAU7gVqOmVWS5F9t7ZyBAawYf6Y7mj8Ul5ik2XRnkzDrnLLnp\nAnp9CC6wem1Tfny6b59eKIwNzWx6Afn70l4l+DsbXtp7VSnt8G1GY2mGtVbRFw70\nJ5UaYdQMNbSkDoF9klJFPEx//mfuD2ndVaexPsvsXpjiyr+hjDNclDkpl7p87XIe\nP7ttLkgYLz6kbTnfziDzyh/RKGFbABAXEzjtSWxojEjdbrKSBbS+G1y8mcMCAwEA\nAQKCAgASnDcZNaD0wXLnPRgQESOQBqWfw9cu8GbsNZ9mjxZlMOSCSx2q/SYgLUpT\nglijSkAbH0HFWNYYnsG5PNKJipbpPOsiYIhwU//GRqckdKqk5oKEVeMmXhn6VWWt\ngo9mPiNV4QUvVdShWT8J8TR9LFAutjcTLJEMMgMZDWPHuiGhJpIhpOt0yweQBSki\nw+HQD1ofFgd924JZt12i+NWHPXXWY+D14lfCujVK78AYU