            "user_data": "#!/bin/bash\nset -e\n\n# Ubuntu uses apt\napt-get update -y\napt-get install -y unzip curl\n\n# Download Dashboard binary\ncurl -L https://github.com/hashicorp/demo-consul-101/releases/download/v0.0.5/dashboard-service_linux_amd64.zip \\\n  -o /tmp/dashboard.zip\ncd /tmp \u0026\u0026 unzip -o dashboard.zip\nmv /tmp/dashboard-service_linux_amd64 /usr/local/bin/dashboard-service\nchmod +x /usr/local/bin/dashboard-service\n\n# Create systemd service\ncat \u003c\u003c'SERVICE' \u003e /etc/systemd/system/dashboard.service\n[Unit]\nDescription=Dashboard Service\nAfter=network.target\n\n[Service]\nEnvironment=\"PORT=9002\"\nEnvironment=\"COUNTING_SERVICE_URL=http://172.16.2.10:9003\"\nExecStart=/usr/local/bin/dashboard-service\nRestart=always\nRestartSec=5\n\n[Install]\nWantedBy=multi-user.target\nSERVICE\n\nsystemctl daemon-reload\nsystemctl enable --now dashboard\n\n# Copy private key so Dashboard EC2 can SSH into Counting EC2\nmkdir -p /home/ubuntu/.ssh\necho \"-----BEGIN RSA PRIVATE KEY-----\nMIIJKAIBAAKCAgEAxNyE9FKGkbLz5U+ru6NKA3twfgKkPVX/gXCW9Ls0f5NyAqVZ\nNvsSx8ZcGaFlQZu+R0+f6W5QnZ9pIltECd8kCa2wjAUNbocVz+7LP+qsRu5qDM9u\nKYcAKFN8ubXJGKxnAOkfROUDX15hu8NI+oDjc2jARCD4zreJk4/+bZZrsDzsqvfE\n1jFAntIA/QJ+gvuA73MtrexXny79j/cGJ2a2pEf/iPq3uAddaMqXr/u88xCmwLNC\n09DjXWqa5BqgcsXQfFS/b2uYWx/uo63mJDiBvRhWaeDb7Hfy0rdXuWVp+XZqN6kd\n5LicSQh8w/A1ZauZNnlKqCc8/TsNwa1X+M3k73ZVrnkk4kls8vZKK30t49cQAky+\nC3xal/d/2KS6MzLEwzpPbkVCLCh3m1GupWEkJrWuK9y/oTOR6aqv/79JGw9hV5UX\nSD5716Mq3c1Gpi0fa7imd5abk2LGxfsbdmEE/78T9o6J4mh4dGoja4oh9po/juQi\n+r4Jf17XFBTYRpikAcRRnPpvoG8tRGjHXitk/Mfz02WOp2JPy/8qoZFxDy1fJFsG\nF6S1sfgk9ue9EZ2Xzr1Q4oqwgH/eNdcatIXRSUxB0YGiIdppMg7JwFbD5PNqfjUY\nlPKIQNUxSbW8JYIEsoDRU1XzgD2XC7JAPM4AwAThin1FXmVhTWGKM80sB5kCAwEA\nAQKCAgAEU6AnoBKdfalpNfhDLHYBf/7rX+Wf4WRIsLcARthl4MXiOt338QpQ4Kxy\nB09cQBTKaMJ8auR5jmQHTpL5OQYfLMnuqvsfnZo3GgQWnZuRwZ4Ae8HOmCpIhD+W\nrfKGXTt6OitBPopM6aIaw9Jwrb9JR5ZaYbOW8YFSjA2Fpe/mSoAjNETqTWwLR2DP\nUakxHNPWslZskHOx6qhFbDnkYEycMyD9WJzGCbvyLN5CS