      "link": null,
      "locked": false,
      "text": "# module.counting-instance.aws_instance.this[0]:\nresource \"aws_instance\" \"this\" {\n    ami                                  = \"ami-0e7ff22101b84bcff\"\n    arn                                  = \"arn:aws:ec2:ap-southeast-1:290094381384:instance/i-09975f63b5455e4cb\"\n    associate_public_ip_address          = false\n    availability_zone                    = \"ap-southeast-1a\"\n    disable_api_stop                     = false\n    disable_api_termination              = false\n    ebs_optimized                        = false\n    force_destroy                        = false\n    get_password_data                    = false\n    hibernation                          = false\n    host_id                              = null\n    iam_instance_profile                 = null\n    id                                   = \"i-09975f63b5455e4cb\"\n    instance_initiated_shutdown_behavior = \"stop\"\n    instance_lifecycle                   = null\n    instance_state                       = \"running\"\n    instance_type                        = \"t3.micro\"\n    ipv6_address_count                   = 0\n    ipv6_addresses                       = []\n    key_name                             = \"dashboard_counting_key_pair\"\n    monitoring                           = false\n    outpost_arn                          = null\n    password_data                        = null\n    placement_group                      = null\n    placement_group_id                   = null\n    placement_partition_number           = 0\n    primary_network_interface_id         = \"eni-04dbc409ee08a188e\"\n    private_dns                          = \"ip-192-168-2-10.ap-southeast-1.compute.internal\"\n    private_ip                           = \"192.168.2.10\"\n    public_dns                           = null\n    public_ip                            = null\n    region                               = \"ap-southeast-1\"\n    secondary_private_ips                = []\n    security_groups                      = []\n    source_dest_check                    = true\n    spot_instance_request_id             = null\n    subnet_id                            = \"subnet-080ee2a90ab79600a\"\n    tags                                 = {\n        \"Name\" = \"counting-app-ec2-instance\"\n    }\n    tags_all                             = {\n        \"Name\" = \"counting-app-ec2-instance\"\n    }\n    tenancy                              = \"default\"\n    user_data                            = <<-EOT\n        #!/bin/bash\n        set -e\n        \n        apt-get update -y\n        apt-get install -y curl unzip\n        \n        # Download Counting binary\n        curl -L https://github.com/hashicorp/demo-consul-101/releases/download/v0.0.5/counting-service_linux_amd64.zip \\\n          -o /tmp/counting.zip\n        cd /tmp && unzip -o counting.zip\n        mv /tmp/counting-service_linux_amd64 /usr/local/bin/counting-service\n        chmod +x /usr/local/bin/counting-service\n        \n        # Create systemd service\n        cat <<'SERVICE' > /etc/systemd/system/counting.service\n        [Unit]\n        Description=Counting Service\n        After=network.target\n        \n        [Service]\n        Environment=\"PORT=9003\"\n        ExecStart=/usr/local/bin/counting-service\n        Restart=always\n        RestartSec=5\n        \n        [Install]\n        WantedBy=multi-user.target\n        SERVICE\n        \n        systemctl daemon-reload\n        systemctl enable --now counting\n    EOT\n    user_data_replace_on_change          = false\n    volume_tags                          = {\n        \"Name\" = \"counting-app-ec2-instance\"\n    }\n    vpc_security_group_ids               = [\n        \"sg-04642f5efab1e943a\",\n        \"sg-0df35e5a35b105b01\",\n    ]\n\n    capacity_reservation_specification {\n        capacity_reservation_preference = \"open\"\n    }\n\n    cpu_options {\n        amd_sev_snp           = null\n        core_count            = 1\n        nested_virtualization = null\n        threads_per_core      = 2\n    }\n\n    credit_specification {\n        cpu_credits = \"unlimited\"\n    }\n\n    enclave_options {\n        enabled = false\n    }\n\n    maintenance_options {\n        auto_recovery = \"default\"\n    }\n\n    metadata_options {\n        http_endpoint               = \"enabled\"\n        http_protocol_ipv6          = \"disabled\"\n        http_put_response_hop_limit = 1\n        http_tokens                 = \"required\"\n        instance_metadata_tags      = \"disabled\"\n    }\n\n    primary_network_interface {\n        delete_on_termination = true\n        network_interface_id  = \"eni-04dbc409ee08a188e\"\n    }\n\n    private_dns_name_options {\n        enable_resource_name_dns_a_record    = false\n        enable_resource_name_dns_aaaa_record = false\n        hostname_type                        = \"ip-name\"\n    }\n\n    root_block_device {\n        delete_on_termination = true\n        device_name           = \"/dev/sda1\"\n        encrypted             = false\n        iops                  = 3000\n        kms_key_id            = null\n        tags                  = {}\n        tags_all              = {}\n        throughput            = 125\n        volume_id             = \"vol-03d6f3fb4489fb2d1\"\n        volume_size           = 8\n        volume_type           = \"gp3\"\n    }\n}",
      "fontSize": 16,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "# module.counting-instance.aws_instance.this[0]:\nresource \"aws_instance\" \"this\" {\n    ami                                  = \"ami-0e7ff22101b84bcff\"\n    arn                                  = \"arn:aws:ec2:ap-southeast-1:290094381384:instance/i-09975f63b5455e4cb\"\n    associate_public_ip_address          = false\n    availability_zone                    = \"ap-southeast-1a\"\n    disable_api_stop                     = false\n    disable_api_termination              = false\n    ebs_optimized                        = false\n    force_destroy                        = false\n    get_password_data                    = false\n    hibernation                          = false\n    host_id                              = null\n    iam_instance_profile                 = null\n    id                                   = \"i-09975f63b5455e4cb\"\n    instance_initiated_shutdown_behavior = \"stop\"\n    instance_lifecycle                   = null\n    instance_state                       = \"running\"\n    instance_type                        = \"t3.micro\"\n    ipv6_address_count                   = 0\n    ipv6_addresses                       = []\n    key_name                             = \"dashboard_counting_key_pair\"\n    monitoring                           = false\n    outpost_arn                          = null\n    password_data                        = null\n    placement_group                      = null\n    placement_group_id                   = null\n    placement_partition_number           = 0\n    primary_network_interface_id         = \"eni-04dbc409ee08a188e\"\n    private_dns                          = \"ip-192-168-2-10.ap-southeast-1.compute.internal\"\n    private_ip                           = \"192.168.2.10\"\n    public_dns                           = null\n    public_ip                            = null\n    region                               = \"ap-southeast-1\"\n    secondary_private_ips                = []\n    security_groups                      = []\n    source_dest_check                    = true\n    spot_instance_request_id             = null\n    subnet_id                            = \"subnet-080ee2a90ab79600a\"\n    tags                                 = {\n        \"Name\" = \"counting-app-ec2-instance\"\n    }\n    tags_all                             = {\n        \"Name\" = \"counting-app-ec2-instance\"\n    }\n    tenancy                              = \"default\"\n    user_data                            = <<-EOT\n        #!/bin/bash\n        set -e\n        \n        apt-get update -y\n        apt-get install -y curl unzip\n        \n        # Download Counting binary\n        curl -L https://github.com/hashicorp/demo-consul-101/releases/download/v0.0.5/counting-service_linux_amd64.zip \\\n          -o /tmp/counting.zip\n        cd /tmp && unzip -o counting.zip\n        mv /tmp/counting-service_linux_amd64 /usr/local/bin/counting-service\n        chmod +x /usr/local/bin/counting-service\n        \n        # Create systemd service\n        cat <<'SERVICE' > /etc/systemd/system/counting.service\n        [Unit]\n        Description=Counting Service\n        After=network.target\n        \n        [Service]\n        Environment=\"PORT=9003\"\n        ExecStart=/usr/local/bin/counting-service\n        Restart=always\n        RestartSec=5\n        \n        [Install]\n        WantedBy=multi-user.target\n        SERVICE\n        \n        systemctl daemon-reload\n        systemctl enable --now counting\n    EOT\n    user_data_replace_on_change          = false\n    volume_tags                          = {\n        \"Name\" = \"counting-app-ec2-instance\"\n    }\n    vpc_security_group_ids               = [\n        \"sg-04642f5efab1e943a\",\n        \"sg-0df35e5a35b105b01\",\n    ]\n\n    capacity_reservation_specification {\n        capacity_reservation_preference = \"open\"\n    }\n\n    cpu_options {\n        amd_sev_snp           = null\n        core_count            = 1\n        nested_virtualization = null\n        threads_per_core      = 2\n    }\n\n    credit_specification {\n        cpu_credits = \"unlimited\"\n    }\n\n    enclave_options {\n        enabled = false\n    }\n\n    maintenance_options {\n        auto_recovery = \"default\"\n    }\n\n    metadata_options {\n        http_endpoint               = \"enabled\"\n        http_protocol_ipv6          = \"disabled\"\n        http_put_response_hop_limit = 1\n        http_tokens                 = \"required\"\n        instance_metadata_tags      = \"disabled\"\n    }\n\n    primary_network_interface {\n        delete_on_termination = true\n        network_interface_id  = \"eni-04dbc409ee08a188e\"\n    }\n\n    private_dns_name_options {\n        enable_resource_name_dns_a_record    = false\n        enable_resource_name_dns_aaaa_record = false\n        hostname_type                        = \"ip-name\"\n    }\n\n    root_block_device {\n        delete_on_termination = true\n        device_name           = \"/dev/sda1\"\n        encrypted             = false\n        iops                  = 3000\n        kms_key_id            = null\n        tags                  = {}\n        tags_all              = {}\n        throughput            = 125\n        volume_id             = \"vol-03d6f3fb4489fb2d1\"\n        volume_size           = 8\n        volume_type           = \"gp3\"\n    }\n}",
